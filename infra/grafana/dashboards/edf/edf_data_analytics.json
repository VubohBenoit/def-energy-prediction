      "id": 200,
      "title": "Consommation électrique (RTE)",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "description": "Derniers 30 jours de données disponibles dans le DW (indépendamment de la date système).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Consommation MW" }, "properties": [{ "id": "color", "value": { "fixedColor": "#E24D42", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Prévision J-1 MW" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 201,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "time_series",
        "rawSql": "WITH bounds AS (SELECT MAX(datetime) AS max_dt FROM dw.fact_consumption_silver) SELECT s.datetime AS time, s.consumption_mw AS \"Consommation MW\", s.forecast_j1_mw AS \"Prévision J-1 MW\" FROM dw.fact_consumption_silver s CROSS JOIN bounds b WHERE s.datetime >= b.max_dt - INTERVAL '30 days' AND s.consumption_mw IS NOT NULL ORDER BY 1",
        "refId": "A"
      }],
      "title": "Consommation horaire vs prévision (30 derniers jours DW)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 202,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "time_series",
        "rawSql": "WITH bounds AS (SELECT MAX(date) AS max_dt FROM dw.agg_daily) SELECT d.date::timestamptz AS time, d.consumption_mean_mw AS \"Conso moyenne MW\", d.peak_consumption_mw AS \"Pic MW\" FROM dw.agg_daily d CROSS JOIN bounds b WHERE d.date >= b.max_dt - INTERVAL '90 days' ORDER BY 1",
        "refId": "A"
      }],
      "title": "Agrégats journaliers — moyenne & pic (90 j)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 203,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "time_series",
        "rawSql": "WITH bounds AS (SELECT MAX(date) AS max_dt FROM dw.agg_daily) SELECT d.date::timestamptz AS time, d.nuclear_share_pct AS \"Nucléaire %\", d.renewable_share_pct AS \"Renouvelables %\" FROM dw.agg_daily d CROSS JOIN bounds b WHERE d.date >= b.max_dt - INTERVAL '90 days' ORDER BY 1",
        "refId": "A"
      }],
      "title": "Mix énergétique journalier (90 j)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "id": 204,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^value$/", "values": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "table",
        "rawSql": "WITH last_day AS (SELECT MAX(date) AS d FROM dw.agg_daily) SELECT 'Nucléaire' AS metric, ROUND(AVG(nuclear_mean_mw)::numeric, 0)::double precision AS value FROM dw.agg_daily, last_day WHERE date >= last_day.d - INTERVAL '30 days' UNION ALL SELECT 'Éolien', ROUND(AVG(wind_mean_mw)::numeric, 0)::double precision FROM dw.agg_daily, last_day WHERE date >= last_day.d - INTERVAL '30 days' UNION ALL SELECT 'Solaire', ROUND(AVG(solar_mean_mw)::numeric, 0)::double precision FROM dw.agg_daily, last_day WHERE date >= last_day.d - INTERVAL '30 days' UNION ALL SELECT 'Hydraulique', ROUND(AVG(hydro_mean_mw)::numeric, 0)::double precision FROM dw.agg_daily, last_day WHERE date >= last_day.d - INTERVAL '30 days'",
        "refId": "A"
      }],
      "title": "Production moyenne par filière (30 j)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "custom": { "axisBorderShow": false },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 18 },
      "id": 205,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single" },
        "xField": "year",
        "xTickLabelRotation": 0
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "table",
        "rawSql": "SELECT year, ROUND(consumption_twh::numeric, 2)::double precision AS consumption_twh FROM dw.v_annual_summary WHERE consumption_twh IS NOT NULL ORDER BY year",
        "refId": "A"
      }],
      "title": "Consommation annuelle (TWh)",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 210,
      "title": "Machine Learning — benchmark modèles",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 27 },
      "id": 211,
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^metric$/", "values": false } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "edf-postgres" }, "editorMode": "code", "format": "table", "rawSql": "SELECT model_name AS metric FROM etl.model_metrics WHERE run_id = (SELECT run_id FROM etl.model_metrics ORDER BY trained_at DESC LIMIT 1) ORDER BY rmse ASC LIMIT 1", "refId": "A" }],
      "title": "Meilleur modèle",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short", "decimals": 1 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 27 },
      "id": 212,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^metric$/", "values": false } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "edf-postgres" }, "editorMode": "code", "format": "table", "rawSql": "SELECT ROUND(MIN(rmse)::numeric, 1)::double precision AS metric FROM etl.model_metrics WHERE run_id = (SELECT run_id FROM etl.model_metrics ORDER BY trained_at DESC LIMIT 1)", "refId": "A" }],
      "title": "RMSE minimal",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 27 },
      "id": 213,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^metric$/", "values": false } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "edf-postgres" }, "editorMode": "code", "format": "table", "rawSql": "SELECT ROUND(MAX(r2)::numeric, 4)::double precision AS metric FROM etl.model_metrics WHERE run_id = (SELECT run_id FROM etl.model_metrics ORDER BY trained_at DESC LIMIT 1)", "refId": "A" }],
      "title": "R² max",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 27 },
      "id": 214,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^metric$/", "values": false } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "edf-postgres" }, "editorMode": "code", "format": "table", "rawSql": "SELECT COUNT(DISTINCT run_id)::double precision AS metric FROM etl.model_metrics", "refId": "A" }],
      "title": "Runs ML enregistrés",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rmse" }, "properties": [{ "id": "displayName", "value": "RMSE" }, { "id": "color", "value": { "fixedColor": "#3274D9", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 31 },
      "id": 215,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.65,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "hidden", "showLegend": false },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single" },
        "xField": "model_name",
        "xTickLabelRotation": 0
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "table",
        "rawSql": "SELECT model_name, ROUND(rmse::numeric, 1)::double precision AS rmse FROM etl.model_metrics WHERE run_id = (SELECT run_id FROM etl.model_metrics ORDER BY trained_at DESC LIMIT 1) ORDER BY rmse ASC",
        "refId": "A"
      }],
      "title": "RMSE par algorithme (dernier run)",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } }, "decimals": 2 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rmse" },
            "properties": [{ "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } }, { "id": "max", "value": 5000 }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 31 },
      "id": 216,
      "options": { "cellHeight": "sm", "showHeader": true, "sortBy": [{ "desc": false, "displayName": "rmse" }] },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "table",
        "rawSql": "SELECT model_name, ROUND(rmse::numeric, 1) AS rmse, ROUND(mae::numeric, 1) AS mae, ROUND(mape_pct::numeric, 2) AS mape_pct, ROUND(r2::numeric, 4) AS r2, ROUND(train_time_s::numeric, 1) AS train_time_s FROM etl.model_metrics WHERE run_id = (SELECT run_id FROM etl.model_metrics ORDER BY trained_at DESC LIMIT 1) ORDER BY rmse ASC",
        "refId": "A"
      }],
      "title": "Métriques détaillées — dernier run ML",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "showPoints": "always", "pointSize": 6 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "id": 217,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "time_series",
        "rawSql": "SELECT trained_at AS time, rmse AS \"RMSE (meilleur modèle/run)\" FROM (SELECT run_id, MIN(rmse) AS rmse, MAX(trained_at) AS trained_at FROM etl.model_metrics GROUP BY run_id) t ORDER BY 1",
        "refId": "A"
      }],
      "title": "Évolution RMSE (meilleur modèle par run)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "edf-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "gCO2/kWh"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 48 },
      "id": 218,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "edf-postgres" },
        "editorMode": "code",
        "format": "time_series",
        "rawSql": "WITH bounds AS (SELECT MAX(date) AS max_dt FROM dw.agg_daily) SELECT d.date::timestamptz AS time, d.co2_mean_gkwh AS \"CO2 moyen g/kWh\" FROM dw.agg_daily d CROSS JOIN bounds b WHERE d.date >= b.max_dt - INTERVAL '180 days' ORDER BY 1",
        "refId": "A"
      }],
      "title": "Intensité carbone journalière (180 j)",
      "type": "timeseries"
    }
